# ============================================
# ERP Sinaran - Docker Environment Variables
# ============================================
# Copy this file to .env.docker and update the values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_sinaran

# ============================================
# API Configuration
# ============================================
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://erp_user:erp_password@db:5432/erp_sinaran
FRONTEND_URL=http://localhost:3000

# ============================================
# Frontend Configuration
# ============================================
REACT_APP_API_BASE_URL=http://localhost:3001
REACT_APP_API_PORT=3001

# ============================================
# Weaving Sync Configuration
# ============================================
WEAVING_IMPORT_API_KEY=sinaran-weaving-sync-secret
