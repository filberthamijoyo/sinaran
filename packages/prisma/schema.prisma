model ImportLog {
  id           Int       @id @default(autoincrement())
  source       String    @db.VarChar(50)
  rows_ok      Int?      @default(0) @map("rows_ok")
  rows_error   Int?      @default(0) @map("rows_error")
  error_detail String?   @map("error_detail")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([createdAt], map: "idx_import_log_created_at")
  @@index([source], map: "idx_import_log_source")
  @@map("ImportLog")
}
