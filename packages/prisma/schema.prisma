generator client {
  provider   = "prisma-client-js"
  output     = "../../node_modules/.prisma/client"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CountDescription {
  code                  Int                    @id
  name                  String                 @db.VarChar(255)
  isActive              Boolean?               @default(true) @map("is_active")
  createdAt             DateTime?              @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime?              @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  indigoDivisionRecords IndigoDivisionRecord[]
  productionRecords     ProductionRecord[]
  yarnTests             YarnTest[]

  @@index([name], map: "idx_count_descriptions_name")
  @@map("count_descriptions")
}

model CountNe {
  id                Int                @id @default(autoincrement())
  value             Decimal            @unique @db.Decimal(10, 2)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  productionRecords ProductionRecord[]
  yarnTests         YarnTest[]

  @@index([value], map: "idx_count_ne_value")
  @@map("count_ne")
}

model Lot {
  id                Int                @id @default(autoincrement())
  code              Int?               @unique
  name              String             @unique @db.VarChar(100)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  blendId           Int?               @map("blend_id")
  blend             Blend?             @relation(fields: [blendId], references: [id], onUpdate: NoAction)
  productionRecords ProductionRecord[]
  yarnTests         YarnTest[]

  @@index([code], map: "idx_lots_code")
  @@index([name], map: "idx_lots_name")
  @@index([blendId], map: "idx_lots_blend_id")
  @@map("lots")
}

model Spk {
  id                Int                @id @default(autoincrement())
  code              Int?               @unique
  name              String             @unique @db.VarChar(100)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  productionRecords ProductionRecord[]
  yarnTests         YarnTest[]

  @@index([code], map: "idx_spks_code")
  @@index([name], map: "idx_spks_name")
  @@map("spks")
}

model YarnType {
  id                Int                @id @default(autoincrement())
  code              Int?               @unique
  name              String             @unique @db.VarChar(100)
  letterCode        String             @map("letter_code") @db.VarChar(10)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  productionRecords ProductionRecord[]
  yarnTests         YarnTest[]

  @@index([code], map: "idx_yarn_types_code")
  @@index([name], map: "idx_yarn_types_name")
  @@index([letterCode], map: "idx_yarn_types_letter_code")
  @@map("yarn_types")
}

model Blend {
  id                Int                @id @default(autoincrement())
  name              String             @unique @db.VarChar(100)
  letterCode        String             @map("letter_code") @db.VarChar(10)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  lots              Lot[]
  productionRecords ProductionRecord[]
  yarnTests         YarnTest[]

  @@index([name], map: "idx_blends_name")
  @@index([letterCode], map: "idx_blends_letter_code")
  @@map("blends")
}

model SlubCode {
  id                Int                @id @default(autoincrement())
  code              String?            @unique @db.VarChar(50)
  description       String?            @db.VarChar(255)
  name              String?            @db.VarChar(100)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  productionRecords ProductionRecord[]
  yarnTests         YarnTest[]

  @@index([code], map: "idx_slub_codes_code")
  @@map("slub_codes")
}

model Kp {
  id                    Int                    @id @default(autoincrement())
  code                  String                 @unique @db.VarChar(50)
  name                  String                 @db.VarChar(100)
  isActive              Boolean?               @default(true) @map("is_active")
  createdAt             DateTime?              @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime?              @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  indigoDivisionRecords IndigoDivisionRecord[]

  @@index([code], map: "idx_kp_code")
  @@index([name], map: "idx_kp_name")
  @@map("kp")
}

model Kode {
  id                    Int                    @id @default(autoincrement())
  code                  String                 @unique @db.VarChar(100)
  name                  String                 @db.VarChar(150)
  isActive              Boolean?               @default(true) @map("is_active")
  createdAt             DateTime?              @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime?              @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  indigoDivisionRecords IndigoDivisionRecord[]

  @@index([code], map: "idx_kode_code")
  @@index([name], map: "idx_kode_name")
  @@map("kodes")
}

model Supplier {
  id        Int        @id @default(autoincrement())
  code      Int        @unique
  name      String     @db.VarChar(100)
  isActive  Boolean?   @default(true) @map("is_active")
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  yarnTests YarnTest[]

  @@index([code], map: "idx_suppliers_code")
  @@index([name], map: "idx_suppliers_name")
  @@map("suppliers")
}

model MillsUnit {
  id                Int                @id @default(autoincrement())
  code              Int                @unique
  name              String             @db.VarChar(50)
  letterCode        String             @map("letter_code") @db.VarChar(10)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  productionRecords ProductionRecord[]
  yarnTests         YarnTest[]

  @@index([code], map: "idx_mills_units_code")
  @@index([name], map: "idx_mills_units_name")
  @@index([letterCode], map: "idx_mills_units_letter_code")
  @@map("mills_units")
}

model ProcessStep {
  id        Int        @id @default(autoincrement())
  code      Int        @unique
  name      String     @db.VarChar(100)
  isActive  Boolean?   @default(true) @map("is_active")
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  yarnTests YarnTest[]

  @@index([code], map: "idx_process_steps_code")
  @@index([name], map: "idx_process_steps_name")
  @@map("process_steps")
}

model TestType {
  id        Int        @id @default(autoincrement())
  code      Int        @unique
  name      String     @db.VarChar(100)
  isActive  Boolean?   @default(true) @map("is_active")
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  yarnTests YarnTest[]

  @@index([code], map: "idx_test_types_code")
  @@index([name], map: "idx_test_types_name")
  @@map("test_types")
}

model Side {
  id        Int        @id @default(autoincrement())
  code      String     @unique @db.VarChar(10)
  name      String     @db.VarChar(50)
  isActive  Boolean?   @default(true) @map("is_active")
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  yarnTests YarnTest[]

  @@index([code], map: "idx_sides_code")
  @@index([name], map: "idx_sides_name")
  @@map("sides")
}

model WarnaConeCheese {
  id                Int                @id @default(autoincrement())
  name              String             @unique @db.VarChar(100)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  productionRecords ProductionRecord[]

  @@index([name], map: "idx_warna_cone_cheese_name")
  @@map("warna_cone_cheese")
}

model RayonBrand {
  id                Int                @id @default(autoincrement())
  name              String             @unique @db.VarChar(100)
  /// 1-letter code for UI display/compact tables (e.g. "A")
  letterCode        String?            @map("letter_code") @db.VarChar(1)
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  productionRecords ProductionRecord[]

  @@index([name], map: "idx_rayon_brand_name")
  @@index([letterCode], map: "idx_rayon_brand_letter_code")
  @@map("rayon_brand")
}

model YarnTest {
  id                   BigInt            @id @default(autoincrement())
  testDate             DateTime          @map("test_date") @db.Date
  testMonth            String?           @map("test_month") @db.VarChar(20)
  testYear             Int?              @map("test_year")
  countDescriptionCode Int?              @map("count_description_code")
  countNeId            Int?              @map("count_ne_id")
  lotId                Int?              @map("lot_id")
  spkId                Int?              @map("spk_id")
  yarnTypeId           Int?              @map("yarn_type_id")
  blendId              Int?              @map("blend_id")
  slubCodeId           Int?              @map("slub_code_id")
  supplierId           Int?              @map("supplier_id")
  millsUnitId          Int?              @map("mills_unit_id")
  processStepId        Int?              @map("process_step_id")
  testTypeId           Int?              @map("test_type_id")
  machineNo            Int?              @map("machine_no")
  sideId               Int?              @map("side_id")
  sliverRovingNe       Decimal?          @map("sliver_roving_ne") @db.Decimal(10, 3)
  totalDraft           Decimal?          @map("total_draft") @db.Decimal(10, 2)
  twistMultiplier      Decimal?          @map("twist_multiplier") @db.Decimal(10, 2)
  tpi                  Decimal?          @db.Decimal(10, 2)
  tpm                  Decimal?          @db.Decimal(10, 2)
  actualTwist          Int?              @map("actual_twist")
  rotorSpindleSpeed    Int?              @map("rotor_spindle_speed")
  meanNe               Decimal?          @map("mean_ne") @db.Decimal(10, 2)
  minNe                Decimal?          @map("min_ne") @db.Decimal(10, 2)
  maxNe                Decimal?          @map("max_ne") @db.Decimal(10, 2)
  cvCountPercent       Decimal?          @map("cv_count_percent") @db.Decimal(10, 2)
  meanStrengthCn       Decimal?          @map("mean_strength_cn") @db.Decimal(10, 2)
  minStrengthCn        Decimal?          @map("min_strength_cn") @db.Decimal(10, 2)
  maxStrengthCn        Decimal?          @map("max_strength_cn") @db.Decimal(10, 2)
  cvStrengthPercent    Decimal?          @map("cv_strength_percent") @db.Decimal(10, 2)
  tenacityCnTex        Decimal?          @map("tenacity_cn_tex") @db.Decimal(10, 2)
  elongationPercent    Decimal?          @map("elongation_percent") @db.Decimal(10, 2)
  clsp                 Decimal?          @db.Decimal(10, 2)
  uPercent             Decimal?          @map("u_percent") @db.Decimal(10, 2)
  cvB                  Decimal?          @map("cv_b") @db.Decimal(10, 2)
  cvm                  Decimal?          @map("cv_m") @db.Decimal(10, 2)
  cvm1m                Decimal?          @map("cvm_1m") @db.Decimal(10, 2)
  cvm3m                Decimal?          @map("cvm_3m") @db.Decimal(10, 2)
  cvm10m               Decimal?          @map("cvm_10m") @db.Decimal(10, 2)
  thin50Percent        Int?              @map("thin_50_percent")
  thick50Percent       Int?              @map("thick_50_percent")
  neps200Percent       Int?              @map("neps_200_percent")
  neps280Percent       Int?              @map("neps_280_percent")
  ipis                 Int?
  oeIpi                Int?              @map("oe_ipi")
  thin30Percent        Int?              @map("thin_30_percent")
  thin40Percent        Int?              @map("thin_40_percent")
  thick35Percent       Int?              @map("thick_35_percent")
  neps140Percent       Int?              @map("neps_140_percent")
  shortIpi             Int?              @map("short_ipi")
  hairiness            Decimal?          @db.Decimal(10, 2)
  sh                   Decimal?          @db.Decimal(10, 2)
  s1uPlusS2u           Decimal?          @map("s1u_plus_s2u") @db.Decimal(10, 2)
  s3u                  Decimal?          @db.Decimal(10, 2)
  dr1_5m5Percent       Decimal?          @map("dr_1_5m_5_percent") @db.Decimal(10, 2)
  remarks              String?
  createdBy            Int?              @map("created_by")
  updatedBy            Int?              @map("updated_by")
  createdAt            DateTime?         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  blend                Blend?            @relation(fields: [blendId], references: [id], onUpdate: NoAction)
  countDescription     CountDescription? @relation(fields: [countDescriptionCode], references: [code], onUpdate: NoAction)
  countNe              CountNe?          @relation(fields: [countNeId], references: [id], onUpdate: NoAction)
  lot                  Lot?              @relation(fields: [lotId], references: [id], onUpdate: NoAction)
  millsUnit            MillsUnit?        @relation(fields: [millsUnitId], references: [id], onUpdate: NoAction)
  processStep          ProcessStep?      @relation(fields: [processStepId], references: [id], onUpdate: NoAction)
  side                 Side?             @relation(fields: [sideId], references: [id], onUpdate: NoAction)
  slubCode             SlubCode?         @relation(fields: [slubCodeId], references: [id], onUpdate: NoAction)
  spk                  Spk?              @relation(fields: [spkId], references: [id], onUpdate: NoAction)
  supplier             Supplier?         @relation(fields: [supplierId], references: [id], onUpdate: NoAction)
  testType             TestType?         @relation(fields: [testTypeId], references: [id], onUpdate: NoAction)
  yarnType             YarnType?         @relation(fields: [yarnTypeId], references: [id], onUpdate: NoAction)

  @@index([testDate], map: "idx_yarn_tests_test_date")
  @@index([testYear, testMonth], map: "idx_yarn_tests_test_year_test_month")
  @@index([countDescriptionCode], map: "idx_yarn_tests_count_description_code")
  @@index([countNeId], map: "idx_yarn_tests_count_ne_id")
  @@index([lotId], map: "idx_yarn_tests_lot_id")
  @@index([spkId], map: "idx_yarn_tests_spk_id")
  @@index([blendId], map: "idx_yarn_tests_blend_id")
  @@index([supplierId], map: "idx_yarn_tests_supplier_id")
  @@index([millsUnitId], map: "idx_yarn_tests_mills_unit_id")
  @@index([processStepId], map: "idx_yarn_tests_process_step_id")
  @@index([testTypeId], map: "idx_yarn_tests_test_type_id")
  @@index([machineNo], map: "idx_yarn_tests_machine_no")
  @@index([createdAt], map: "idx_yarn_tests_created_at")
  @@map("yarn_tests")
}

/// Main fact table for daily production records.
model ProductionRecord {
  id                                             BigInt            @id @default(autoincrement())
  /// Calendar date of production (column: Date)
  productionDate                                 DateTime          @map("production_date") @db.Date
  /// Month text, e.g. "Februari" (column: Month)
  month                                          String            @db.VarChar(20)
  /// Year extracted from productionDate (column: Year)
  year                                           Int?              @map("year")
  /// Unit / mill name (unified MillsUnit dimension, column: mills_unit_id)
  millsUnitId                                    Int               @map("mills_unit_id")
  /// Yarn type descriptor, e.g. OE, RING (column: Yarn Jenis Benang)
  yarnTypeId                                     Int               @map("yarn_type_id")
  /// Yarn count Ne (column: Count (Ne))
  countNeId                                      Int               @map("count_ne_id")
  /// Denormalized count Ne value for calculations (populated from countNe relation)
  countNeValue                                   Decimal           @map("count_ne_value") @db.Decimal(10, 2)
  /// Optional Count Description code (unified with Quality module)
  /// Links to CountDescription.code (1–36 base set plus any dynamic extensions)
  countDescriptionCode                           Int?              @map("count_description_code")
  /// Slub code, if any (column: Slub Code)
  slubCodeId                                     Int?              @map("slub_code_id")
  /// Lot identifier (column: Lot Benang)
  lotId                                          Int?              @map("lot_id")
  /// SPK identifier (column: SPK)
  spkId                                          Int?              @map("spk_id")
  /// Blend identifier (unified dimension table)
  blendId                                        Int?              @map("blend_id")
  /// Cone / cheese colour (column: Warna Cone / Cheese)
  warnaConeCheeseId                              Int?              @map("warna_cone_cheese_id")
  /// Rayon brand (dimension table reference)
  rayonBrandId                                   Int?              @map("rayon_brand_id")
  /// Cone / cheese weight in kilograms (column: Berat Cone / Cheese (Kgs))
  beratConeCheeseKg                              Decimal           @map("berat_cone_cheese_kg") @db.Decimal(10, 3)
  /// Twist multiplier TM (column: TM)
  tm                                             Decimal           @db.Decimal(10, 2)
  /// TPI is calculated as TM * sqrt(countNeValue) but stored here as a column for import.
  /// Formula: TPI = TM * sqrt(countNeValue)
  tpi                                            Decimal           @db.Decimal(10, 3)
  /// Machine speed (column: Speed)
  speed                                          Int
  /// Installed spindles / rotors (column: Jumlah Spindel / Rotor Terpasang)
  jumlahSpindelRotorTerpasang                    Int               @map("jumlah_spindel_rotor_terpasang")
  /// Actual production - cone/cheese quantity (column under Aktual Produksi: Jumlah Cones / Cheese)
  jumlahConesCheese                              Int               @map("jumlah_cones_cheese")
  /// Actual production in kilograms (Produksi (Kgs)).
  /// Formula: produksiKgs = beratConeCheeseKg * jumlahConesCheese
  produksiKgs                                    Decimal           @map("produksi_kgs") @db.Decimal(14, 3)
  /// Actual production in pounds (Produksi (Lbs)).
  /// Formula: produksiLbs = beratConeCheeseKg * jumlahConesCheese * 2.2046
  produksiLbs                                    Decimal           @map("produksi_lbs") @db.Decimal(14, 3)
  /// Actual production in bales (Aktual Produksi (Bales)).
  /// Formula: aktualProduksiBales = produksiLbs / 400
  aktualProduksiBales                            Decimal           @map("aktual_produksi_bales") @db.Decimal(14, 4)
  /// 100% production capacity in bales (100% Produksi (Bales)).
  /// Formula:
  /// 100% produksi(bales) =
  /// (jumlahSpindelRotorTerpasang * speed * 1440) /
  /// (countNeValue * tpi * 840 * 36 * 400)
  produksi100PercentBales                        Decimal           @map("produksi_100_percent_bales") @db.Decimal(14, 4)
  /// Target production on target OPR (Target Produksi on Target OPR (Bales)).
  /// Formula:
  /// targetProduksiOnTargetOprBales =
  /// jumlahSpindelRotorTerpasang * targetOpsOpr * 3 / 16 / 400
  targetProduksiOnTargetOprBales                 Decimal           @map("target_produksi_on_target_opr_bales") @db.Decimal(14, 4)
  /// Gain / loss of efficiency in bales versus target OPS/OPR
  /// (Keuntungan atau Kerugian Efisiensi Bales on Target OPS / OPR).
  /// Formula:
  /// keuntunganKerugianEfisiensiBalesOnTargetOpsOpr =
  /// (opsOprWorked - targetOpsOpr) *
  /// jumlahSpindelRotorTerpasang * 3 / 16 / 400
  keuntunganKerugianEfisiensiBalesOnTargetOpsOpr Decimal           @map("keuntungan_kerugian_efisiensi_bales_on_target_ops_opr") @db.Decimal(14, 4)
  /// Target OPS/OPR.
  /// Formula:
  /// targetOpsOpr = 0.254 * speed * 0.9 / tpi / countNeValue
  targetOpsOpr                                   Decimal           @map("target_ops_opr") @db.Decimal(12, 6)
  /// Actual OPS/OPR based on total installed spindles.
  /// Formula:
  /// opsOprAktual = (produksiLbs * 16) / 3 / jumlahSpindelRotorTerpasang
  opsOprAktual                                   Decimal           @map("ops_opr_aktual") @db.Decimal(12, 6)
  /// OPS/OPR worked (from sheet column "OPS / OPR Worked").
  opsOprWorked                                   Decimal           @map("ops_opr_worked") @db.Decimal(12, 6)
  /// Production efficiency percentage (Produksi Effisiensi %).
  /// Formula:
  /// produksiEffisiensiPercent = aktualProduksiBales / produksi100PercentBales
  produksiEffisiensiPercent                      Decimal           @map("produksi_effisiensi_percent") @db.Decimal(8, 4)
  /// Work efficiency percentage (Effisiensi % Kerja).
  /// Formula:
  /// effisiensiKerjaPercent =
  /// (opsOprWorked * jumlahSpindelRotorTerpasang * 3 / 1600 / 4) /
  /// produksi100PercentBales
  effisiensiKerjaPercent                         Decimal           @map("effisiensi_kerja_percent") @db.Decimal(8, 4)
  /// Stoppage minutes - Power / Electric (min).
  powerElectricMin                               Int?              @map("power_electric_min")
  /// Stoppage minutes - Count Mengubah (min).
  countMengubahMin                               Int?              @map("count_mengubah_min")
  /// Stoppage minutes - Creel Mengubah (min).
  creelMengubahMin                               Int?              @map("creel_mengubah_min")
  /// Stoppage minutes - Preventive Mtc/Rotor/Ring Change Stoppage (min).
  preventiveMtcMin                               Int?              @map("preventive_mtc_min")
  /// Stoppage minutes - Creel Short Stoppage (min).
  creelShortStoppageMin                          Int?              @map("creel_short_stoppage_min")
  /// Total stoppage minutes (Total Penghentian (min)).
  /// Formula:
  /// totalPenghentianMin =
  /// powerElectricMin + countMengubahMin + creelMengubahMin +
  /// preventiveMtcMin + creelShortStoppageMin
  totalPenghentianMin                            Int?              @map("total_penghentian_min")
  /// Working spindles / rotors (Spindles / Rotors Bekerja).
  /// Formula:
  /// spindlesRotorsBekerja =
  /// ((jumlahSpindelRotorTerpasang * 1440) -
  /// (jumlahSpindelRotorTerpasang * totalPenghentianMin)) / 1440
  spindlesRotorsBekerja                          Decimal?          @map("spindles_rotors_bekerja") @db.Decimal(14, 4)
  /// Spindle / rotor efficiency (Spindle / Rotors Effisiensi).
  /// Formula:
  /// spindlesRotorsEffisiensi =
  /// spindlesRotorsBekerja / jumlahSpindelRotorTerpasang
  spindlesRotorsEffisiensi                       Decimal?          @map("spindles_rotors_effisiensi") @db.Decimal(10, 6)
  /// Loss due to power stoppage (Power Penghentian).
  /// Formula:
  /// powerPenghentian =
  /// -(opsOprWorked * 3 *
  /// (jumlahSpindelRotorTerpasang * powerElectricMin / 1440) /
  /// 16 / 400)
  powerPenghentian                               Decimal?          @map("power_penghentian") @db.Decimal(14, 4)
  /// Loss due to count change (Count Mengubah).
  /// Formula:
  /// countMengubahLoss =
  /// -(opsOprWorked * 3 *
  /// (jumlahSpindelRotorTerpasang * countMengubahMin / 1440)) /
  /// 16 / 400
  countMengubahLoss                              Decimal?          @map("count_mengubah_loss") @db.Decimal(14, 4)
  /// Loss due to creel change (Creel Mengubah).
  /// Formula:
  /// creelMengubahLoss =
  /// -(opsOprWorked * 3 *
  /// (jumlahSpindelRotorTerpasang * creelMengubahMin / 1440)) /
  /// 16 / 400
  creelMengubahLoss                              Decimal?          @map("creel_mengubah_loss") @db.Decimal(14, 4)
  /// Loss due to preventive maintenance / rotor / ring cup change.
  /// Formula:
  /// preventiveMtcLoss =
  /// -(opsOprWorked * 3 *
  /// (jumlahSpindelRotorTerpasang * preventiveMtcMin / 1440)) /
  /// 16 / 400
  preventiveMtcLoss                              Decimal?          @map("preventive_mtc_loss") @db.Decimal(14, 4)
  /// Loss due to Creel (Sliver/Roving) Short.
  /// Formula:
  /// creelShortLoss =
  /// -(opsOprWorked * 3 *
  /// (jumlahSpindelRotorTerpasang * creelShortStoppageMin / 1440)) /
  /// 16 / 400
  creelShortLoss                                 Decimal?          @map("creel_short_loss") @db.Decimal(14, 4)
  /// Total loss due to stoppage (Kerugian Total).
  /// Formula:
  /// kerugianTotal =
  /// -(opsOprWorked * 3 *
  /// (jumlahSpindelRotorTerpasang * totalPenghentianMin / 1440)) /
  /// 16 / 400
  kerugianTotal                                  Decimal?          @map("kerugian_total") @db.Decimal(14, 4)
  /// Yarn price per bale (Harga Benang per Bale).
  hargaBenangPerBale                             Decimal?          @map("harga_benang_per_bale") @db.Decimal(12, 2)
  createdAt                                      DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                                      DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  blend                                          Blend?            @relation(fields: [blendId], references: [id], onUpdate: NoAction)
  countDescription                               CountDescription? @relation(fields: [countDescriptionCode], references: [code], onUpdate: NoAction)
  countNe                                        CountNe           @relation(fields: [countNeId], references: [id], onUpdate: NoAction)
  lot                                            Lot?              @relation(fields: [lotId], references: [id], onUpdate: NoAction)
  millsUnit                                      MillsUnit         @relation(fields: [millsUnitId], references: [id], onUpdate: NoAction)
  rayonBrand                                     RayonBrand?       @relation(fields: [rayonBrandId], references: [id], onUpdate: NoAction)
  slubCode                                       SlubCode?         @relation(fields: [slubCodeId], references: [id], onUpdate: NoAction)
  spk                                            Spk?              @relation(fields: [spkId], references: [id], onUpdate: NoAction)
  warnaConeCheese                                WarnaConeCheese?  @relation(fields: [warnaConeCheeseId], references: [id], onUpdate: NoAction)
  yarnType                                       YarnType          @relation(fields: [yarnTypeId], references: [id], onUpdate: NoAction)

  @@index([productionDate], map: "idx_production_records_production_date")
  @@index([month], map: "idx_production_records_month")
  @@index([year], map: "idx_production_records_year")
  @@index([year, month], map: "idx_production_records_year_month")
  @@index([millsUnitId], map: "idx_production_records_mills_unit_id")
  @@index([yarnTypeId], map: "idx_production_records_yarn_type_id")
  @@index([countNeId], map: "idx_production_records_count_ne_id")
  @@index([countDescriptionCode], map: "idx_production_records_count_description_code")
  @@index([blendId], map: "idx_production_records_blend_id")
  @@index([slubCodeId], map: "idx_production_records_slub_code_id")
  @@index([lotId], map: "idx_production_records_lot_id")
  @@index([spkId], map: "idx_production_records_spk_id")
  @@index([warnaConeCheeseId], map: "idx_production_records_warna_cone_cheese_id")
  @@index([rayonBrandId], map: "idx_production_records_rayon_brand_id")
  @@map("production_records")
}

