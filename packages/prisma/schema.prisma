  p_tumpuk          Int?           // Tumpuk
  b_bar             Int?           // Bercak
  sml               Int?           // Semel
  p_slub            Int?           // Putus Slub
  p_belang          Int?           // Pilih Belang
  crossing          Int?
  x_sambang         Int?           // Sambungan
  p_jelek           Int?           // Pilih Jelek
  lipatan           Int?           // Lipatan
  
  weaving_record    WeavingRecord? @relation(fields: [weaving_record_id], references: [id])

  @@unique([kp, mc, bm, no_pot])
  @@index([kp])
  @@index([tg])
  @@index([mc, bm])
  @@index([no_pot])
  @@index([tgl_potong])
  @@index([sn_combined])
}

