{
  "name": "api",
  "version": "1.0.0",
  "description": "Unified API server for ERP Sinaran",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run prisma:generate && tsc",
    "postinstall": "npm run prisma:generate",
    "start": "node dist/server.js",
    "prisma:generate": "npm run generate --workspace=@erp-sinaran/prisma",
    "prisma:studio": "npm run studio --workspace=@erp-sinaran/prisma",
    "prisma:migrate": "npm run migrate:dev --workspace=@erp-sinaran/prisma"
  },
  "dependencies": {
    "@erp-sinaran/prisma": "*",
    "@prisma/client": "^6.16.1",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
